# Postgres connection for the example app (used by `pnpm start` AND `pnpm test:e2e`).
# Copy this file to `.env` and set your credentials once — no need to type them
# on every run. Create the database first, e.g. `createdb nest_crud_example`.

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nest_crud_e2e

# Or a single connection string (takes precedence over the DB_* vars above):
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/nest_crud_example
