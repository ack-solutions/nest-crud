# Postgres connection for the e2e tests (apps/example-app/test/*.e2e-spec.ts).
# Copy this file to `.env` and edit. Once `.env` exists, the Postgres e2e suites
# run with `pnpm test:e2e` — no need to type the variables each time.
#
# These defaults match the bundled docker-compose.yml, so `pnpm db:up` + the file
# below work with zero changes.

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nest_crud_e2e

# Or a single connection string (takes precedence over the DB_* vars above):
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/nest_crud_e2e
